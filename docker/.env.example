# =============================================================
# OJS Docker — Environment Variables
# Copy to .env and fill in real values
# =============================================================

# --- Database ---
DB_ROOT_PASSWORD=CHANGE_ME_root_password_here
DB_NAME=ojs
DB_USER=ojs
DB_PASSWORD=CHANGE_ME_ojs_password_here

# --- OJS ---
OJS_DOMAIN=journal.example.com
OJS_ADMIN_USER=admin
OJS_ADMIN_PASSWORD=CHANGE_ME_admin_password_here
OJS_ADMIN_EMAIL=admin@example.com

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- SSL (Let's Encrypt) ---
CERTBOT_EMAIL=admin@example.com

# --- Backup ---
BACKUP_DIR=/opt/backups/ojs
BACKUP_RETENTION_DAYS=30

# --- Timezone ---
TZ=Asia/Almaty
